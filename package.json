{
  "name": "hash256-auto-miner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "mine": "node mine.mjs",
    "check": "node mine.mjs --status --no-submit",
    "dashboard": "node dashboard.mjs",
    "gpu": "node gpu.mjs",
    "h98": "node h98/h98.mjs",
    "h98:check": "node h98/h98.mjs --status",
    "h98:gpu": "node h98/h98-gpu.mjs",
    "equium": "powershell -ExecutionPolicy Bypass -File equium/run-equium.ps1",
    "equium:setup": "powershell -ExecutionPolicy Bypass -File equium/run-equium.ps1 -BuildOnly",
    "equium:validate": "powershell -ExecutionPolicy Bypass -File equium/run-equium.ps1 -ValidateKeypairs",
    "equium:status": "powershell -ExecutionPolicy Bypass -File equium/run-equium.ps1 -Status",
    "equium:stop": "powershell -ExecutionPolicy Bypass -File equium/run-equium.ps1 -Stop",
    "equium:watch": "powershell -ExecutionPolicy Bypass -File equium/watch-equium.ps1"
  },
  "dependencies": {
    "viem": "^2.39.3"
  }
}
