# Ethereum mainnet RPC endpoint. Use your own provider for stable mining.
RPC_URL=https://ethereum-rpc.publicnode.com

# Optional. Required only if you want the script to submit mine(nonce).
# Never paste a wallet with funds you cannot risk.
PRIVATE_KEY=

# Required when PRIVATE_KEY is empty, so the script can request getChallenge(address).
MINER_ADDRESS=

# 1 keeps polling until mining opens, and keeps mining after accepted transactions.
KEEP_MINING=0

# CPU workers. Default is min(8, available cores - 1).
WORKERS=

# Hashes per wasm batch per worker. Larger is faster but less responsive.
BATCH_SIZE=250000

# Seconds between chain checks while searching. Lower reacts faster to stale challenges.
RETARGET_SECONDS=3

# Optional: 1 skips the final freshness check and gas estimation for faster submit.
# This can waste gas if the nonce is already stale.
FAST_SUBMIT=0
