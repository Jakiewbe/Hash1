# Ethereum mainnet RPC endpoint. Use your own provider for stable mining.
RPC_URL=https://ethereum-rpc.publicnode.com

# Optional private transaction RPC used only for submitting signed mine() txs.
# Examples: https://rpc.mevblocker.io/fast or https://rpc.flashbots.net/fast
SUBMIT_RPC_URL=

# Optional. Required only if you want the script to submit mine(nonce).
# Never paste a wallet with funds you cannot risk.
PRIVATE_KEY=

# Required when PRIVATE_KEY is empty, so the script can request getChallenge(address).
MINER_ADDRESS=

# 1 keeps polling until mining opens, and keeps mining after accepted transactions.
KEEP_MINING=0

# CPU workers. Default is min(8, available cores - 1).
WORKERS=

# Hashes per wasm batch per worker. Larger is faster but less responsive.
BATCH_SIZE=250000

# Seconds between chain checks while searching. Lower reacts faster to stale challenges.
RETARGET_SECONDS=3

# Optional: 1 skips the final freshness check and gas estimation for faster submit.
# This can waste gas if the nonce is already stale.
FAST_SUBMIT=0

# Optional EIP-1559 fee overrides for faster inclusion.
# Competitive miners may use several gwei of priority fee.
PRIORITY_FEE_GWEI=
MAX_FEE_GWEI=

# H98 / h98hash.xyz miner settings.
# This script intentionally uses H98_PRIVATE_KEYS only, not PRIVATE_KEY.
H98_RPC_URL=https://ethereum-rpc.publicnode.com
H98_SUBMIT_RPC_URL=
# Comma or space separated on one line. Prefer h98-accounts.txt for many keys.
H98_PRIVATE_KEYS=
H98_ACCOUNTS_FILE=h98-accounts.txt
H98_KEEP_MINING=1
H98_WORKERS_PER_ACCOUNT=1
H98_BATCH_SIZE=50000
H98_RETARGET_SECONDS=15
H98_FAST_SUBMIT=0
H98_PRIORITY_FEE_GWEI=
H98_MAX_FEE_GWEI=

# Local browser WebGPU miner for H98.
H98_GPU_PORT=8798
H98_GPU_NO_SUBMIT=0

# Equium / equium.xyz Solana miner wrapper settings.
# Uses Solana keypair JSON files, not Ethereum private keys.
EQUIUM_RPC_URL=https://api.mainnet-beta.solana.com
EQUIUM_KEYPAIRS_FILE=equium/keypairs.txt
EQUIUM_WORKERS_PER_KEYPAIR=1
EQUIUM_MAX_BLOCKS=0
EQUIUM_MAX_NONCES_PER_ROUND=4096
EQUIUM_CU_LIMIT=1400000
EQUIUM_CACHE_DIR=
EQUIUM_WATCH_CHECK_SECONDS=60
EQUIUM_WATCH_BACKOFF_SECONDS=20
EQUIUM_WATCH_MAX_RESTARTS=0
